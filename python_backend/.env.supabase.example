# Supabase Database Configuration
# Copy this file to .env.supabase and fill in your details

# Get these from: Supabase Dashboard → Settings → Database → Connection string
DB_HOST=db.xxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.xxxxxxxxxxxxx
DB_PASSWORD=your-super-secret-database-password

# For production, use connection pooling:
# DB_HOST=db.xxxxxxxxxxxxx.pooler.supabase.com
# DB_PORT=6543

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key
DEBUG=False
PYTHON_PORT=5000
HOST=0.0.0.0

# Optional: Admin setup key for secure operations
ADMIN_SETUP_KEY=your-admin-setup-key
